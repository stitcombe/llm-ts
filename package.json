{
  "name": "llm-ts",
  "version": "0.32.0-alpha.3",
  "description": "TypeScript port of the llm CLI utility and library for interacting with Large Language Models",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "llm": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "better-sqlite3": "^11.10.0",
    "js-yaml": "^4.1.0",
    "llm-ts": "link:",
    "pluggy-ts": "file:../pluggy-ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
